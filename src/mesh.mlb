(* MLB for the sml-obj library: vendored sml-glm core plus the mesh sources.
 * Consumers reference this file. The dependency .mlb is brought in WITHOUT a
 * `local` wrapper so consumers may `open Glm` alongside Mesh. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-glm/glm.mlb
mesh.sig
mesh.sml
